---
import SubpageLayout from '../layouts/SubpageLayout.astro';
---

<SubpageLayout title="Contact">
  <div class="w-full max-w-xl p-8 md:p-10 rounded-2xl bg-[#090d1a]/90 border border-white/10 shadow-2xl hover:border-white/20 transition-all duration-500 my-auto will-change-[transform,opacity]">
    
    <h2 class="text-2xl md:text-3xl font-bold text-white font-['Orbitron'] mb-2 tracking-widest text-center uppercase bg-gradient-to-r from-white to-white/60 bg-clip-text text-transparent">
      Get in Touch
    </h2>
    
    <p class="text-center text-sm text-white/50 font-sans mb-8 tracking-wide">
      Available for collaborations and creative partnerships. Let's build something epic.
    </p>
    
    <form action="https://api.web3forms.com/submit" method="POST" class="flex flex-col gap-y-6">
        
        <input type="hidden" name="access_key" value="d60bb63f-d89d-4331-bfb0-2e2da59d6972">
        
        <input type="hidden" name="redirect" value="https://smajlo.com/success">
        
        <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div class="flex flex-col gap-y-1.5">
            <label class="block text-white/50 text-xs font-['Orbitron'] uppercase tracking-wider">Name</label>
            <input type="text" name="name" required 
                   class="w-full px-4 py-3 rounded-lg bg-slate-900/60 border border-white/10 text-white focus:outline-none focus:border-white/40 focus:ring-1 focus:ring-white/20 transition duration-300">
          </div>

          <div class="flex flex-col gap-y-1.5">
            <label class="block text-white/50 text-xs font-['Orbitron'] uppercase tracking-wider">Email Address</label>
            <input type="email" name="email" required 
                   class="w-full px-4 py-3 rounded-lg bg-slate-900/60 border border-white/10 text-white focus:outline-none focus:border-white/40 focus:ring-1 focus:ring-white/20 transition duration-300">
          </div>
        </div>

        <div class="flex flex-col gap-y-1.5">
          <label class="block text-white/50 text-xs font-['Orbitron'] uppercase tracking-wider">Subject</label>
          <input type="text" name="subject" required 
                 class="w-full px-4 py-3 rounded-lg bg-slate-900/60 border border-white/10 text-white focus:outline-none focus:border-white/40 focus:ring-1 focus:ring-white/20 transition duration-300">
        </div>

        <div class="flex flex-col gap-y-1.5">
          <label class="block text-white/50 text-xs font-['Orbitron'] uppercase tracking-wider">Message</label>
          <textarea name="message" rows="5" required 
                    class="w-full px-4 py-3 rounded-lg bg-slate-900/60 border border-white/10 text-white focus:outline-none focus:border-white/40 focus:ring-1 focus:ring-white/20 transition duration-300 resize-none"
                    placeholder="Tell me about your project or collaboration idea..."></textarea>
        </div>

        <button type="submit" 
                class="mt-2 w-full py-4 bg-white/5 hover:bg-white text-white hover:text-slate-950 font-['Orbitron'] font-bold uppercase tracking-widest rounded-lg border border-white/20 transition-all duration-300 ease-out shadow-[0_0_0_0_rgba(255,255,255,0)] hover:shadow-[0_0_20px_0_rgba(255,255,255,0.35)] will-change-transform transform active:scale-[0.98]">
          Send Message
        </button>
    </form>
  </div>
</SubpageLayout>
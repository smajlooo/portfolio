---
import SubpageLayout from '../layouts/SubpageLayout.astro';
---

<SubpageLayout title="Message Sent">
  <div class="w-full max-w-md p-8 md:p-10 rounded-2xl bg-[#090d1a]/90 border border-white/10 shadow-2xl text-center my-auto will-change-[transform,opacity]">
    
    <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-white/5 border border-white/20 mb-6 shadow-[0_0_15px_rgba(255,255,255,0.1)]">
      <svg class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </div>

    <h2 class="text-2xl font-bold text-white font-['Orbitron'] mb-3 tracking-widest uppercase bg-gradient-to-r from-white to-white/60 bg-clip-text text-transparent">
      Transmission Received
    </h2>
    
    <p class="text-sm text-white/50 font-sans mb-8 tracking-wide leading-relaxed">
      Thank you for reaching out! Your message has been successfully routed. I will review it and get back to you shortly.
    </p>
    
    <a href="/contact" 
       class="inline-block w-full py-4 bg-white/5 hover:bg-white text-white hover:text-slate-950 font-['Orbitron'] font-bold uppercase tracking-widest rounded-lg border border-white/20 transition-all duration-300 ease-out shadow-[0_0_0_0_rgba(255,255,255,0)] hover:shadow-[0_0_20px_0_rgba(255,255,255,0.35)] text-xs">
      Back to Contact
    </a>
  </div>
</SubpageLayout>
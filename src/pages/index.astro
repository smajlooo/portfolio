---
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>smajlooo</title>
	</head>
	<body>
		<canvas id="particleCanvas"></canvas>

		<svg class="web-menu" id="spiderWeb" viewBox="0 0 1920 1080" preserveAspectRatio="none">
			</svg>

		<script>
			// ==========================================
            // 1. BASIS-BERECHNUNG DES SPINNENNETZES (Muss zuerst kommen!)
            // ==========================================
            const svg = document.getElementById('spiderWeb');
            const numRays = 7;       
            const numRings = 5;      
            const svgWidth = 1920;  // Konsistenter Name für beide Skripte
            const svgHeight = 1080;

            const angles = [];
            for (let i = 0; i < numRays; i++) {
                const angle = (i / (numRays - 1)) * (Math.PI / 2);
                angles.push(angle);

                let x2 = svgWidth;
                let y2 = svgHeight;
                if (Math.cos(angle) * svgHeight > Math.sin(angle) * svgWidth) {
                    x2 = svgWidth;
                    y2 = svgWidth * Math.tan(angle);
                } else {
                    y2 = svgHeight;
                    x2 = svgHeight / Math.tan(angle);
                }

                const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
                line.setAttribute("class", "spider-line");
                line.setAttribute("x1", "0");
                line.setAttribute("y1", "0");
                line.setAttribute("x2", x2.toString());
                line.setAttribute("y2", y2.toString());
                svg.appendChild(line);
            }

            for (let r = 1; r <= numRings; r++) {
                const radius = (svgWidth * 1.4) * (r / numRings); 

                for (let i = 0; i < numRays - 1; i++) {
                    const a1 = angles[i];
                    const a2 = angles[i + 1];

                    const xStart = radius * Math.cos(a1);
                    const yStart = radius * Math.sin(a1);
                    const xEnd = radius * Math.cos(a2);
                    const yEnd = radius * Math.sin(a2);

                    const midAngle = (a1 + a2) / 2;
                    const sagFactor = 0.88; 
                    const xCtrl = radius * Math.cos(midAngle) * sagFactor;
                    const yCtrl = radius * Math.sin(midAngle) * sagFactor;

                    const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
                    path.setAttribute("class", "spider-line");
                    path.setAttribute("d", `M ${xStart},${yStart} Q ${xCtrl},${yCtrl} ${xEnd},${yEnd}`);
                    svg.appendChild(path);
                }
            }

            const menuItems = [
                { text: "About",     rayStart: 1, ringStart: 2, url: "/about" },
                { text: "Über uns",  rayStart: 3, ringStart: 2, url: "/ueber-uns" },
                { text: "Projekte",  rayStart: 4, ringStart: 3, url: "/projekte" },
                { text: "Kontakt",   rayStart: 2, ringStart: 4, url: "/kontakt" }
            ];

            menuItems.forEach(item => {
                const a1 = angles[item.rayStart];
                const a2 = angles[item.rayStart + 1];
                const midAngle = (a1 + a2) / 2;

                const r1 = (svgWidth * 1.4) * (item.ringStart / numRings);
                const r2 = (svgWidth * 1.4) * ((item.ringStart + 1) / numRings);
                const midRadius = (r1 + r2) / 2;

                const cx = midRadius * Math.cos(midAngle) * 0.94;
                const cy = midRadius * Math.sin(midAngle) * 0.94;

                const a = document.createElementNS("http://www.w3.org/2000/svg", "a");
                a.setAttribute("href", item.url);
                a.setAttribute("class", "menu-link");

                const text = document.createElementNS("http://www.w3.org/2000/svg", "text");
                text.setAttribute("x", cx.toString());
                text.setAttribute("y", cy.toString());
                text.textContent = item.text;

                a.appendChild(text);
                svg.appendChild(a);
            });


            // ==========================================
            // 2. ENTLANG DER GEOMETRIE FLIESSENDE PARTIKEL
            // ==========================================
            const canvas = document.getElementById('particleCanvas');
            const ctx = canvas.getContext('2d');

            function resizeCanvas() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            window.addEventListener('resize', resizeCanvas);
            resizeCanvas();

            const particles = [];
            const particleCount = 180; // Leicht erhöht für einen dichteren Flow!

            class NetworkParticle {
                constructor() {
                    this.reset();
                    this.progress = Math.random(); 
                }

                reset() {
                    this.speed = (Math.random() * 0.003 + 0.0015); 
                    this.direction = Math.random() > 0.5 ? 1 : -1;
                    this.size = Math.random() * 2.5 + 1.5;
                    
                    this.onTrack = Math.random() > 0.4 ? 'ray' : 'ring';
                    
                    if (this.onTrack === 'ray') {
                        this.rayIndex = Math.floor(Math.random() * numRays);
                    } else {
                        this.ringIndex = Math.floor(Math.random() * numRings) + 1; 
                        this.rayStart = Math.floor(Math.random() * (numRays - 1));
                    }
                }

                update() {
                    this.progress += this.speed * this.direction;
                    
                    if (this.progress > 1) {
                        this.progress = 1;
                        this.direction = -1;
                    } else if (this.progress < 0) {
                        this.progress = 0;
                        this.direction = 1;
                    }

                    if (this.onTrack === 'ray') {
                        const angle = angles[this.rayIndex];
                        let maxRadius = svgWidth;
                        if (Math.cos(angle) * svgHeight > Math.sin(angle) * svgWidth) {
                            maxRadius = svgWidth / Math.cos(angle);
                        } else {
                            maxRadius = svgHeight / Math.sin(angle);
                        }
                        
                        const currentRadius = maxRadius * this.progress;
                        const svgX = currentRadius * Math.cos(angle);
                        const svgY = currentRadius * Math.sin(angle);
                        
                        this.x = (svgX / svgWidth) * canvas.width;
                        this.y = (svgY / svgHeight) * canvas.height;

                    } else {
                        const radius = (svgWidth * 1.4) * (this.ringIndex / numRings);
                        const a1 = angles[this.rayStart];
                        const a2 = angles[this.rayStart + 1];
                        
                        const xStart = radius * Math.cos(a1);
                        const yStart = radius * Math.sin(a1);
                        const xEnd = radius * Math.cos(a2);
                        const yEnd = radius * Math.sin(a2);
                        
                        const midAngle = (a1 + a2) / 2;
                        const sagFactor = 0.88;
                        const xCtrl = radius * Math.cos(midAngle) * sagFactor;
                        const yCtrl = radius * Math.sin(midAngle) * sagFactor;
                        
                        const t = this.progress;
                        const svgX = (1 - t) * (1 - t) * xStart + 2 * (1 - t) * t * xCtrl + t * t * xEnd;
                        const svgY = (1 - t) * (1 - t) * yStart + 2 * (1 - t) * t * yCtrl + t * t * yEnd;
                        
                        this.x = (svgX / svgWidth) * canvas.width;
                        this.y = (svgY / svgHeight) * canvas.height;
                    }
                }

                draw() {
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                    ctx.fillStyle = 'rgba(255, 255, 255, 0.85)';
                    ctx.fill();
                    
                    ctx.shadowBlur = 5;
                    ctx.shadowColor = '#ffffff';
                }
            }

            for (let i = 0; i < particleCount; i++) {
                particles.push(new NetworkParticle());
            }

            function animate() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                for (let i = 0; i < particles.length; i++) {
                    particles[i].update();
                    particles[i].draw();
                }
                requestAnimationFrame(animate);
            }
            animate();
		</script>
	</body>
</html>



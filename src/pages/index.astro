---
import '../styles/global.css';
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>smajlooo</title>
    </head>
    <body>
        <canvas id="particleCanvas"></canvas>

        <svg class="web-menu" id="spiderWeb" viewBox="0 0 1920 1080" preserveAspectRatio="none">
        </svg>

        <script>
            // ==========================================
            // 1. BASE CALCULATION OF THE SPIDER WEB
            // ==========================================
            const svg = document.getElementById('spiderWeb');
            const numRays = 7;       
            const numRings = 5;      
            const svgWidth = 1920;  
            const svgHeight = 1080;

            const angles = [];
            const trackPoints = []; 

            // Generate rays
            for (let i = 0; i < numRays; i++) {
                const angle = (i / (numRays - 1)) * (Math.PI / 2);
                angles.push(angle);

                let x2 = svgWidth;
                let y2 = svgHeight;
                if (Math.cos(angle) * svgHeight > Math.sin(angle) * svgWidth) {
                    x2 = svgWidth;
                    y2 = svgWidth * Math.tan(angle);
                } else {
                    y2 = svgHeight;
                    x2 = svgHeight / Math.tan(angle);
                }

                for (let t = 0; t <= 1; t += 0.02) {
                    trackPoints.push({
                        x: x2 * t,
                        y: y2 * t,
                        nx: -Math.sin(angle),
                        ny: Math.cos(angle)
                    });
                }

                const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
                line.setAttribute("class", "spider-line");
                line.setAttribute("x1", "0");
                line.setAttribute("y1", "0");
                line.setAttribute("x2", x2.toString());
                line.setAttribute("y2", y2.toString());
                
                // --- WELCOME ANIMATION FOR RAYS ---
                // Setup CSS variables for dynamic length calculation
                const length = Math.sqrt(x2*x2 + y2*y2);
                line.style.strokeDasharray = length.toString();
                line.style.strokeDashoffset = length.toString();
                line.style.animation = `weaveLine 1.4s cubic-bezier(0.25, 1, 0.5, 1) forwards`;
                line.style.animationDelay = `${i * 0.08}s`; // Sequential fan-out effect
                
                svg.appendChild(line);
            }

            // Store intersection points for anchoring
            const intersections = [];

            // Generate rings
            for (let r = 1; r <= numRings; r++) {
                const radius = (svgWidth * 1.4) * (r / numRings); 
                intersections[r] = [];

                for (let i = 0; i < numRays; i++) {
                    const angle = angles[i];
                    intersections[r].push({
                        x: radius * Math.cos(angle),
                        y: radius * Math.sin(angle)
                    });
                }

                for (let i = 0; i < numRays - 1; i++) {
                    const a1 = angles[i];
                    const a2 = angles[i + 1];

                    const xStart = radius * Math.cos(a1);
                    const yStart = radius * Math.sin(a1);
                    const xEnd = radius * Math.cos(a2);
                    const yEnd = radius * Math.sin(a2);

                    const midAngle = (a1 + a2) / 2;
                    const sagFactor = 0.88; 
                    const xCtrl = radius * Math.cos(midAngle) * sagFactor;
                    const yCtrl = radius * Math.sin(midAngle) * sagFactor;

                    for (let t = 0; t <= 1; t += 0.03) {
                        const currX = (1 - t) * (1 - t) * xStart + 2 * (1 - t) * t * xCtrl + t * t * xEnd;
                        const currY = (1 - t) * (1 - t) * yStart + 2 * (1 - t) * t * yCtrl + t * t * yEnd;
                        const currentAngle = a1 + (a2 - a1) * t;

                        trackPoints.push({ 
                            x: currX, 
                            y: currY,
                            nx: -Math.sin(currentAngle),
                            ny: Math.cos(currentAngle)
                        });
                    }

                    const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
                    path.setAttribute("class", "spider-line");
                    path.setAttribute("d", `M ${xStart},${yStart} Q ${xCtrl},${yCtrl} ${xEnd},${yEnd}`);
                    
                    // --- WELCOME ANIMATION FOR ARCHED RINGS ---
                    // Approximate path length for the web segments
                    const approxLength = Math.sqrt((xEnd - xStart)**2 + (yEnd - yStart)**2) * 1.2;
                    path.style.strokeDasharray = approxLength.toString();
                    path.style.strokeDashoffset = approxLength.toString();
                    path.style.animation = `weaveLine 1.2s cubic-bezier(0.25, 1, 0.5, 1) forwards`;
                    // Expands from inside out
                    path.style.animationDelay = `${0.4 + (r * 0.15) + (i * 0.05)}s`;

                    svg.appendChild(path);
                }
            }

            // ==========================================
            // OPTION 1: DIAGONAL ALIGNMENT (TEXT ONLY)
            // ==========================================
            
            // ==========================================
            // OPTION 1: DIAGONAL ALIGNMENT (TEXT ONLY)
            // ==========================================
            const menuItems = [
                { text: "About",      rayStart: 0, ringStart: 2, url: "/about" },      
                { text: "Projects",   rayStart: 1, ringStart: 2, url: "/projects" },   
                { text: "Experience", rayStart: 2, ringStart: 2, url: "/experience" }, 
                { text: "Tech Stack", rayStart: 3, ringStart: 2, url: "/tech-stack" }  
            ];

            menuItems.forEach((item, index) => {
                const a1 = angles[item.rayStart];
                const a2 = angles[item.rayStart + 1];
                const midAngle = (a1 + a2) / 2;

                const r1 = (svgWidth * 1.4) * (item.ringStart / numRings);
                const r2 = (svgWidth * 1.4) * ((item.ringStart + 1) / numRings);
                const midRadius = (r1 + r2) / 2;

                const visualRadius = midRadius * 0.96; 
                const cx = visualRadius * Math.cos(midAngle);
                const cy = visualRadius * Math.sin(midAngle);

                const a = document.createElementNS("http://www.w3.org/2000/svg", "a");
                a.setAttribute("href", item.url);
                a.setAttribute("class", "menu-link");

                const text = document.createElementNS("http://www.w3.org/2000/svg", "text");
                text.setAttribute("x", cx.toString());
                text.setAttribute("y", cy.toString());
                text.setAttribute("dominant-baseline", "central");
                text.textContent = item.text;

                // Welcome animation for menu items
                text.style.opacity = "0";
                text.style.transform = "scale(0.8)";
                text.style.transformOrigin = `${cx}px ${cy}px`;
                text.style.animation = `fadeInText 1s cubic-bezier(0.34, 1.56, 0.64, 1) forwards`;
                text.style.animationDelay = `${1.2 + (index * 0.15)}s`;

                a.appendChild(text);
                svg.appendChild(a);
            });

            // ==========================================
            // NEW: SPIDERMAN WELCOME MESSAGE
            // ==========================================
            // Target the red marked area (Ray 1 to 2, outer ring)
            const welcomeAngle1 = angles[1];
            const welcomeAngle2 = angles[2];
            // Exact mathematical center between Ray 1 and Ray 2
            const welcomeMidAngle = (welcomeAngle1 + welcomeAngle2) / 2;

            const welcomeR1 = (svgWidth * 1.4) * (3 / numRings);
            const welcomeR2 = (svgWidth * 1.4) * (4 / numRings);
            // Perfect radius center between Ring 3 and Ring 4
            const welcomeMidRadius = (welcomeR1 + welcomeR2) / 2;

            // Trigonometric alignment with balanced padding
            const welcomeVisualRadius = welcomeMidRadius * 0.95;
            const welcomeCx = welcomeVisualRadius * Math.cos(welcomeMidAngle);
            const welcomeCy = welcomeVisualRadius * Math.sin(welcomeMidAngle);

            // Container for the welcome text lines
            const welcomeGroup = document.createElementNS("http://www.w3.org/2000/svg", "g");
            welcomeGroup.setAttribute("class", "welcome-message-group");

            const lines = [
                { text: "Welcome!", offset: -30, size: "28px", weight: "700" },
                { text: "Just your friendly neighborhood", offset: 10, size: "18px", weight: "500" },
                { text: "tech guy.", offset: 40, size: "18px", weight: "500" }
            ];

            lines.forEach((lineData) => {
                const tNode = document.createElementNS("http://www.w3.org/2000/svg", "text");
                tNode.setAttribute("x", welcomeCx.toString());
                tNode.setAttribute("y", (welcomeCy + lineData.offset).toString());
                tNode.setAttribute("text-anchor", "middle");
                tNode.setAttribute("dominant-baseline", "central");
                tNode.textContent = lineData.text;
                
                tNode.style.fontFamily = "'Orbitron', sans-serif";
                tNode.style.fontSize = lineData.size;
                tNode.style.fontWeight = lineData.weight;
                tNode.style.fill = "rgba(255, 255, 255, 0.85)";
                tNode.style.letterSpacing = "2px";
                tNode.style.pointerEvents = "none"; 
                tNode.style.filter = "drop-shadow(0px 0px 5px rgba(255, 255, 255, 0.3))";

                welcomeGroup.appendChild(tNode);
            });

            // Animate the entire welcome block to fade in alongside the menu
            welcomeGroup.style.opacity = "0";
            welcomeGroup.style.transform = "translateY(10px)";
            welcomeGroup.style.animation = "fadeInWelcome 1.2s ease-out forwards";
            welcomeGroup.style.animationDelay = "1.8s"; 

            svg.appendChild(welcomeGroup);

            // ==========================================
            // 2. SLOW-MOTION DNA HELIX PHYSICS
            // ==========================================
            const canvas = document.getElementById('particleCanvas');
            const ctx = canvas.getContext('2d');

            function resizeCanvas() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            window.addEventListener('resize', resizeCanvas);
            resizeCanvas();

            const particles = [];
            const particleCount = 170; 
            const captureRadius = 80;     
            const snapSpeed = 0.02;       

            class DNAFlowParticle {
                constructor() {
                    this.x = Math.random() * canvas.width;
                    this.y = Math.random() * canvas.height;
                    this.vx = (Math.random() - 0.5) * 0.2; 
                    this.vy = (Math.random() - 0.5) * 0.2;
                    this.size = Math.random() * 1.8 + 1.2;
                    
                    this.waveAmplitude = Math.random() * 14 + 7;      
                    this.waveSpeed = Math.random() * 0.0012 + 0.0006;  
                    this.randomPhase = Math.random() * Math.PI * 2;   
                    this.flowDirection = Math.random() > 0.5 ? 1 : -1;
                }

                update() {
                    this.x += this.vx;
                    this.y += this.vy;

                    if (this.x < 0 || this.x > canvas.width) this.vx *= -1;
                    if (this.y < 0 || this.y > canvas.height) this.vy *= -1;

                    const svgX = (this.x / canvas.width) * svgWidth;
                    const svgY = (this.y / canvas.height) * svgHeight;

                    let closestTrackPoint = null;
                    let closestDist = captureRadius;

                    trackPoints.forEach(pt => {
                        const dist = Math.sqrt((svgX - pt.x) ** 2 + (svgY - pt.y) ** 2);
                        if (dist < closestDist) {
                            closestDist = dist;
                            closestTrackPoint = pt;
                        }
                    });

                    if (closestTrackPoint !== null) {
                        const canvasTargetX = (closestTrackPoint.x / svgWidth) * canvas.width;
                        const canvasTargetY = (closestTrackPoint.y / svgHeight) * canvas.height;

                        const perpX = closestTrackPoint.nx;
                        const perpY = closestTrackPoint.ny;

                        const timeFactor = Date.now() * this.waveSpeed + this.randomPhase;
                        const currentWaveOffset = Math.sin(timeFactor) * this.waveAmplitude;

                        const finalTargetX = canvasTargetX + perpX * currentWaveOffset;
                        const finalTargetY = canvasTargetY + perpY * currentWaveOffset;

                        this.vx += (finalTargetX - this.x) * snapSpeed;
                        this.vy += (finalTargetY - this.y) * snapSpeed;

                        const flowSpeed = 0.04; 
                        this.vx += -perpY * flowSpeed * this.flowDirection;
                        this.vy += perpX * flowSpeed * this.flowDirection;

                        this.vx *= 0.82;
                        this.vy *= 0.82;
                    } else {
                        this.vx += (Math.random() - 0.5) * 0.01;
                        this.vy += (Math.random() - 0.5) * 0.01;
                        this.vx *= 0.97;
                        this.vy *= 0.97;
                    }
                }

                draw() {
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                    ctx.fillStyle = 'rgba(255, 255, 255, 0.65)';
                    ctx.fill();
                    
                    ctx.shadowBlur = 3;
                    ctx.shadowColor = '#ffffff';
                }
            }

            for (let i = 0; i < particleCount; i++) {
                particles.push(new DNAFlowParticle());
            }

            function animate() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                for (let i = 0; i < particles.length; i++) {
                    particles[i].update();
                    particles[i].draw();

                    for (let j = i + 1; j < particles.length; j++) {
                        let dx = particles[i].x - particles[j].x;
                        let dy = particles[i].y - particles[j].y;
                        let distance = Math.sqrt(dx * dx + dy * dy);

                        if (distance < 45) {
                            let opacity = 1 - (distance / 45);
                            ctx.beginPath();
                            ctx.moveTo(particles[i].x, particles[i].y);
                            ctx.lineTo(particles[j].x, particles[j].y);
                            ctx.shadowBlur = 0; 
                            ctx.strokeStyle = `rgba(255, 255, 255, ${opacity * 0.08})`; 
                            ctx.lineWidth = 0.7;
                            ctx.stroke();
                        }
                    }
                }
                requestAnimationFrame(animate);
            }
            animate();
        </script>
    </body>
</html>
---
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>smajlooo</title>
	</head>
	<body>
		<canvas id="particleCanvas"></canvas>

		<svg class="web-menu" id="spiderWeb" viewBox="0 0 1920 1080" preserveAspectRatio="none">
			</svg>

		<script>
			// ==========================================
            // 1. BASIS-BERECHNUNG DES SPINNENNETZES (Liefert die Magnet-Linien)
            // ==========================================
            const svg = document.getElementById('spiderWeb');
            const numRays = 7;       
            const numRings = 5;      
            const svgWidth = 1920;  
            const svgHeight = 1080;

            const angles = [];
            const linesData = []; // Speichert die geraden Linien für die Partikel-Abstimmung

            for (let i = 0; i < numRays; i++) {
                const angle = (i / (numRays - 1)) * (Math.PI / 2);
                angles.push(angle);

                let x2 = svgWidth;
                let y2 = svgHeight;
                if (Math.cos(angle) * svgHeight > Math.sin(angle) * svgWidth) {
                    x2 = svgWidth;
                    y2 = svgWidth * Math.tan(angle);
                } else {
                    y2 = svgHeight;
                    x2 = svgHeight / Math.tan(angle);
                }

                // Daten für den Magnet-Effekt merken
                linesData.push({ x1: 0, y1: 0, x2: x2, y2: y2 });

                const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
                line.setAttribute("class", "spider-line");
                line.setAttribute("x1", "0");
                line.setAttribute("y1", "0");
                line.setAttribute("x2", x2.toString());
                line.setAttribute("y2", y2.toString());
                svg.appendChild(line);
            }

            // Speichert Punkte entlang der Bögen, um sie als Magneten zu nutzen
            const arcPoints = []; 

            for (let r = 1; r <= numRings; r++) {
                const radius = (svgWidth * 1.4) * (r / numRings); 

                for (let i = 0; i < numRays - 1; i++) {
                    const a1 = angles[i];
                    const a2 = angles[i + 1];

                    const xStart = radius * Math.cos(a1);
                    const yStart = radius * Math.sin(a1);
                    const xEnd = radius * Math.cos(a2);
                    const yEnd = radius * Math.sin(a2);

                    const midAngle = (a1 + a2) / 2;
                    const sagFactor = 0.88; 
                    const xCtrl = radius * Math.cos(midAngle) * sagFactor;
                    const yCtrl = radius * Math.sin(midAngle) * sagFactor;

                    // Generiere ein paar Stützpunkte auf dem Bogen für die Anziehung
                    for (let t = 0; t <= 1; t += 0.25) {
                        const currX = (1 - t) * (1 - t) * xStart + 2 * (1 - t) * t * xCtrl + t * t * xEnd;
                        const currY = (1 - t) * (1 - t) * yStart + 2 * (1 - t) * t * yCtrl + t * t * yEnd;
                        arcPoints.push({ x: currX, y: currY });
                    }

                    const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
                    path.setAttribute("class", "spider-line");
                    path.setAttribute("d", `M ${xStart},${yStart} Q ${xCtrl},${yCtrl} ${xEnd},${yEnd}`);
                    svg.appendChild(path);
                }
            }

            const menuItems = [
                { text: "About",     rayStart: 1, ringStart: 2, url: "/about" },
                { text: "Über uns",  rayStart: 3, ringStart: 2, url: "/ueber-uns" },
                { text: "Projekte",  rayStart: 4, ringStart: 3, url: "/projekte" },
                { text: "Kontakt",   rayStart: 2, ringStart: 4, url: "/kontakt" }
            ];

            menuItems.forEach(item => {
                const a1 = angles[item.rayStart];
                const a2 = angles[item.rayStart + 1];
                const midAngle = (a1 + a2) / 2;

                const r1 = (svgWidth * 1.4) * (item.ringStart / numRings);
                const r2 = (svgWidth * 1.4) * ((item.ringStart + 1) / numRings);
                const midRadius = (r1 + r2) / 2;

                const cx = midRadius * Math.cos(midAngle) * 0.94;
                const cy = midRadius * Math.sin(midAngle) * 0.94;

                const a = document.createElementNS("http://www.w3.org/2000/svg", "a");
                a.setAttribute("href", item.url);
                a.setAttribute("class", "menu-link");

                const text = document.createElementNS("http://www.w3.org/2000/svg", "text");
                text.setAttribute("x", cx.toString());
                text.setAttribute("y", cy.toString());
                text.textContent = item.text;

                a.appendChild(text);
                svg.appendChild(a);
            });


            // ==========================================
            // 2. ANSATZ 2: FREIE PARTIKEL MIT MAGNET-NETZANZIEHUNG
            // ==========================================
            const canvas = document.getElementById('particleCanvas');
            const ctx = canvas.getContext('2d');

            function resizeCanvas() {
                canvas.width = window.innerWidth;
                canvas.height = window.innerHeight;
            }
            window.addEventListener('resize', resizeCanvas);
            resizeCanvas();

            const particles = [];
            const particleCount = 220; // Schöne Balance zwischen Dichte und Performance
            const attractionRadius = 60; // Wie nah muss ein Punkt sein, um angezogen zu werden?
            const attractionStrength = 0.04; // Wie stark zieht das Netz (0.01 - 0.1)

            // Hilfsfunktion: Kürzester Abstand von Punkt zu einer Linie
            function getDistanceToLine(px, py, x1, y1, x2, y2) {
                const dx = x2 - x1;
                const dy = y2 - y1;
                const t = Math.max(0, Math.min(1, ((px - x1) * dx + (py - y1) * dy) / (dx * dx + dy * dy)));
                const nearestX = x1 + t * dx;
                const nearestY = y1 + t * dy;
                return {
                    dist: Math.sqrt((px - nearestX) ** 2 + (py - nearestY) ** 2),
                    x: nearestX,
                    y: nearestY
                };
            }

            class MagneticParticle {
                constructor() {
                    this.x = Math.random() * canvas.width;
                    this.y = Math.random() * canvas.height;
                    this.vx = (Math.random() - 0.5) * 1.0; 
                    this.vy = (Math.random() - 0.5) * 1.0;
                    this.size = Math.random() * 2.5 + 1.2;
                }

                update() {
                    this.x += this.vx;
                    this.y += this.vy;

                    // Bildschirmränder abprallen
                    if (this.x < 0 || this.x > canvas.width) this.vx *= -1;
                    if (this.y < 0 || this.y > canvas.height) this.vy *= -1;

                    // Partikelposition zurück in das virtuelle 1920x1080 SVG-Raster rechnen
                    const svgX = (this.x / canvas.width) * svgWidth;
                    const svgY = (this.y / canvas.height) * svgHeight;

                    let targetX = null;
                    let targetY = null;
                    let closestDist = attractionRadius;

                    // 1. Anziehung durch die geraden Strahlen prüfen
                    linesData.forEach(line => {
                        const res = getDistanceToLine(svgX, svgY, line.x1, line.y1, line.x2, line.y2);
                        if (res.dist < closestDist) {
                            closestDist = res.dist;
                            targetX = res.x;
                            targetY = res.y;
                        }
                    });

                    // 2. Anziehung durch die Kreisbögen prüfen
                    arcPoints.forEach(pt => {
                        const dist = Math.sqrt((svgX - pt.x) ** 2 + (svgY - pt.y) ** 2);
                        if (dist < closestDist) {
                            closestDist = dist;
                            targetX = pt.x;
                            targetY = pt.y;
                        }
                    });

                    // Wenn eine Linie nah genug ist -> Sanft dorthin ziehen
                    if (targetX !== null && targetY !== null) {
                        // Ziel wieder auf echte Canvas-Größe umrechnen
                        const canvasTargetX = (targetX / svgWidth) * canvas.width;
                        const canvasTargetY = (targetY / svgHeight) * canvas.height;

                        this.vx += (canvasTargetX - this.x) * attractionStrength * 0.1;
                        this.vy += (canvasTargetY - this.y) * attractionStrength * 0.1;
                        
                        // Geschwindigkeit drosseln, damit sie geschmeidig auf den Linien "surfen"
                        this.vx *= 0.98;
                        this.vy *= 0.98;
                    }
                }

                draw() {
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                    ctx.fillStyle = 'rgba(255, 255, 255, 0.75)';
                    ctx.fill();
                    
                    ctx.shadowBlur = 4;
                    ctx.shadowColor = '#ffffff';
                }
            }

            for (let i = 0; i < particleCount; i++) {
                particles.push(new MagneticParticle());
            }

            function animate() {
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                for (let i = 0; i < particles.length; i++) {
                    particles[i].update();
                    particles[i].draw();

                    // Zeichne feine, dezente Verbindungslinien NUR zwischen den Partikeln selbst
                    for (let j = i + 1; j < particles.length; j++) {
                        let dx = particles[i].x - particles[j].x;
                        let dy = particles[i].y - particles[j].y;
                        let distance = Math.sqrt(dx * dx + dy * dy);

                        if (distance < 90) {
                            let opacity = 1 - (distance / 90);
                            ctx.beginPath();
                            ctx.moveTo(particles[i].x, particles[i].y);
                            ctx.lineTo(particles[j].x, particles[j].y);
                            ctx.shadowBlur = 0; 
                            ctx.strokeStyle = `rgba(255, 255, 255, ${opacity * 0.22})`; 
                            ctx.lineWidth = 1.0;
                            ctx.stroke();
                        }
                    }
                }
                requestAnimationFrame(animate);
            }
            animate();
		</script>
	</body>
</html>


